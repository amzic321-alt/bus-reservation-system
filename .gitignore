# ============================================
# Bus Seat Reservation System - .gitignore
# ============================================

# ---- Data files (auto-generated by the program) ----
bookings.dat
*.dat
*.bin

# ---- Compiled executables ----
bus_reservation
bus_reservation.exe
*.exe
*.out
*.app

# ---- Object files (compiled but not linked) ----
*.o
*.obj
*.dll
*.so
*.dylib

# ---- Debug and build directories ----
Debug/
Release/
build/
bin/
obj/

# ---- IDE and text editor temporary files ----
# Visual Studio Code
.vscode/
*.code-workspace

# Visual Studio
*.sln
*.vcxproj
*.vcxproj.filters
*.suo
*.user

# CLion / IntelliJ
.idea/
*.iml
cmake-build-*/

# CodeBlocks
*.cbp
*.depend
*.layout

# Eclipse
.project
.classpath
.settings/

# Text editors
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
*.tmp

# ---- Logs and test outputs ----
*.log
*.txt   # Optional: if you don't want text files (but you might want to keep README.md)

# ---- Mac OS specific ----
.DS_Store
.AppleDouble
.LSOverride

# ---- Windows specific ----
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Linux specific ----
.directory
*.pid
*.lock